NODE_ENV=development
PORT=3010

# Supabase / PostgreSQL connection URIs
# Use the Supabase pooler URL for DATABASE_URL and the direct connection for DIRECT_URL.
# Replace <PROJECT_REF> and <PASSWORD> with the values from your Supabase dashboard.
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require

# Clerk keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
